{
  "name": "@midlane/vscode",
  "displayName": "Midlane Language Support",
  "description": "Syntax highlighting for Midlane schema files.",
  "version": "0.0.0",
  "private": true,
  "publisher": "midlane",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "build": "node -e \"\"",
    "check-types": "node -e \"\"",
    "lint": "biome ci .",
    "test": "node -e \"\""
  },
  "contributes": {
    "languages": [
      {
        "id": "midlane",
        "aliases": [
          "Midlane",
          "midlane"
        ],
        "extensions": [
          ".midlane"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "midlane",
        "scopeName": "source.midlane",
        "path": "./syntaxes/midlane.tmLanguage.json"
      }
    ]
  }
}
