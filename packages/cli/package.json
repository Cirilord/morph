{
  "name": "@midlane/cli",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "bin": {
    "midlane": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup --watch",
    "lint": "biome ci .",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@midlane/config": "0.0.0",
    "@midlane/generator": "0.0.0",
    "@midlane/parser": "0.0.0",
    "cac": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "5.9.2",
    "vitest": "^4.1.4"
  }
}
