{
  "name": "midlane",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome ci .",
    "format": "biome check --write .",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "midlane": "node packages/midlane/bin/midlane.js"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@tsconfig/strictest": "^2.0.8",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "packages/*"
  ]
}
